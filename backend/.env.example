# ============================================================
# AutoStudio AI Backend - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp backend/.env.example backend/.env
#
# NEVER commit .env to version control.
# ============================================================

# ---- Database (REQUIRED) ----
# Docker Compose (default): postgres service name resolves automatically
DATABASE_URL=postgresql://autostudio_user:autostudio@postgres:5432/autostudio
# External PostgreSQL: use host/port of your external server
# DATABASE_URL=postgresql://autostudio_user:YOUR_PASSWORD@YOUR_DB_HOST:5432/autostudio

# ---- JWT Authentication (REQUIRED) ----
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-generate-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Stripe (optional for development) ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Frontend URL ----
FRONTEND_URL=http://localhost:3000

# ---- App Configuration ----
APP_NAME=AutoStudio AI
APP_URL=http://localhost:8000

# ---- Admin Configuration ----
ADMIN_PASSWORD=CHANGE-ME-set-a-secure-admin-password

# ---- Background Removal ----
ENABLE_REMBG=true
BG_REMOVAL_ENGINE=rembg
# Docker Compose: use service name; Local dev: use http://localhost:7000
REMBG_SERVICE_URL=http://rembg:7000