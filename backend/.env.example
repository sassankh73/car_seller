# ============================================================
# AutoStudio AI Backend - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp backend/.env.example backend/.env
#
# NEVER commit .env to version control.
# ============================================================

# ---- Environment (REQUIRED) ----
# "development" bypasses the production Stripe-key fail-fast check at startup.
# Set to "production" only once real (non-placeholder) Stripe keys are configured below.
ENVIRONMENT=development

# ---- Database (REQUIRED) ----
# Docker Compose (default): postgres service name resolves automatically
DATABASE_URL=postgresql://autostudio_user:autostudio@postgres:5432/autostudio
# External PostgreSQL: use host/port of your external server
# DATABASE_URL=postgresql://autostudio_user:YOUR_PASSWORD@YOUR_DB_HOST:5432/autostudio

# ---- JWT Authentication (REQUIRED) ----
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-generate-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Stripe (optional for development) ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Frontend URL ----
FRONTEND_URL=http://localhost:3000

# ---- CORS (REQUIRED) ----
# Comma-separated list of origins allowed to call the API. Must include every origin
# you actually load the frontend from (add your server/droplet IP or domain here too).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- App Configuration ----
APP_NAME=AutoStudio AI
APP_URL=http://localhost:8000

# ---- Admin Configuration (REQUIRED — both must be set or no admin account is created) ----
ADMIN_EMAIL=admin@autostudio.local
ADMIN_PASSWORD=CHANGE-ME-set-a-secure-admin-password

# ---- Background Removal ----
ENABLE_REMBG=true
BG_REMOVAL_ENGINE=rembg
# Docker Compose: use service name; Local dev: use http://localhost:7000
REMBG_SERVICE_URL=http://rembg:7000

# ---- Image Processing Feature Flags ----
# Enhancement (paint reflection + wheel sharpening) — disabled by default as it reduces quality
ENABLE_ENHANCEMENT=false
# Lighting correction — disabled by default as it can degrade image quality
ENABLE_LIGHTING_CORRECTION=false
