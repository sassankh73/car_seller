{
  "project": {
    "name": "AutoStudio",
    "version": "1.0.0",
    "description": "AI-powered automotive photography processing platform — background removal, color grading, and studio-quality enhancement for car dealerships and automotive photographers.",
    "owner": "Sassan Khalebani",
    "email": "sassankh@gmail.com",
    "created": "2026-06-09"
  },

  "brand": {
    "logo": {
      "type": "svg-inline",
      "description": "Red sports car silhouette with camera shutter aperture, wordmark Auto (white) + Studio (red)",
      "file": "assets/autostudio-logo.svg",
      "colors": {
        "car": "#CC2020",
        "shutter": "#CC2020",
        "wordmark_auto": "#FFFFFF",
        "wordmark_studio": "#CC2020",
        "background": "transparent"
      },
      "sizes": {
        "sidebar": { "height": 32, "width": "auto" },
        "mobile_header": { "height": 28, "width": "auto" },
        "favicon": { "size": 32 },
        "og_image": { "width": 1200, "height": 630 }
      }
    },
    "colors": {
      "primary": "#CC2020",
      "primary_dark": "#991818",
      "primary_light": "#E53535",
      "accent": "#CC2020",
      "background": "#0f0f0f",
      "surface": "#1a1a1a",
      "surface_raised": "#242424",
      "border": "#2e2e2e",
      "text_primary": "#FAFAFA",
      "text_muted": "#A1A1AA",
      "success": "#22C55E",
      "warning": "#F59E0B",
      "danger": "#EF4444"
    },
    "typography": {
      "heading_font": "Fira Code",
      "body_font": "Fira Sans",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap",
      "scale": {
        "xs": "11px",
        "sm": "13px",
        "base": "14px",
        "md": "16px",
        "lg": "18px",
        "xl": "22px",
        "2xl": "28px"
      }
    }
  },

  "ui": {
    "style": "flat-dark",
    "border_radius": {
      "sm": "6px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "spacing_unit": 4,
    "transitions": {
      "fast": "150ms ease",
      "normal": "200ms ease",
      "slow": "300ms cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "z_index": {
      "dropdown": 10,
      "sticky": 20,
      "fixed": 30,
      "modal_backdrop": 40,
      "modal": 50,
      "toast": 60
    },
    "breakpoints": {
      "mobile": "0px",
      "tablet": "768px",
      "desktop": "1024px",
      "wide": "1440px"
    },
    "layout": {
      "sidebar_width_desktop": "240px",
      "sidebar_width_tablet": "64px",
      "topbar_height": "56px",
      "mobile_header_height": "57px",
      "bottom_nav_height": "60px",
      "content_max_width": "1280px"
    }
  },

  "studios": [
    {
      "id": "glamour",
      "name": "Glamour Studio",
      "description": "High-gloss automotive finish with dramatic lighting and deep shadow work. Ideal for luxury and performance vehicles.",
      "status": "active",
      "supported_formats": ["jpg", "jpeg", "png", "webp", "heic"],
      "max_resolution": "50MP",
      "processing_time_est": "45s",
      "features": ["background_removal", "color_grading", "reflection_enhancement", "dust_removal"]
    },
    {
      "id": "dealership",
      "name": "Dealership Studio",
      "description": "Clean white or gray studio backgrounds optimized for e-commerce listings and inventory management systems.",
      "status": "active",
      "supported_formats": ["jpg", "jpeg", "png", "webp"],
      "max_resolution": "24MP",
      "processing_time_est": "30s",
      "features": ["background_removal", "white_balance", "straighten", "batch_processing"]
    },
    {
      "id": "outdoor",
      "name": "Outdoor Studio",
      "description": "Sky replacement and environment enhancement for on-location automotive shoots.",
      "status": "beta",
      "supported_formats": ["jpg", "jpeg", "raw", "png"],
      "max_resolution": "50MP",
      "processing_time_est": "90s",
      "features": ["sky_replacement", "road_reflection", "environment_lighting", "color_grading"]
    },
    {
      "id": "interior",
      "name": "Interior Studio",
      "description": "Specialized processing for car interior shots with HDR tone-mapping and detail enhancement.",
      "status": "new",
      "supported_formats": ["jpg", "jpeg", "png", "raw"],
      "max_resolution": "36MP",
      "processing_time_est": "60s",
      "features": ["hdr_tonemapping", "noise_reduction", "window_masking", "detail_sharpening"]
    }
  ],

  "workflow": {
    "steps": [
      { "id": 1, "key": "select_studio", "label": "Select Studio", "description": "Choose the processing style for your vehicle photos" },
      { "id": 2, "key": "upload_photos", "label": "Upload Photos", "description": "Upload JPG, PNG or WebP files up to 50MB each" },
      { "id": 3, "key": "configure", "label": "Configure", "description": "Adjust processing settings, output format, and resolution" },
      { "id": 4, "key": "process", "label": "Process", "description": "AI processes your images in the selected studio style" },
      { "id": 5, "key": "download", "label": "Download", "description": "Download individual images or export as a ZIP bundle" }
    ],
    "max_batch_size": 100,
    "supported_output_formats": ["jpg", "png", "webp"],
    "default_output_quality": 92
  },

  "mobile": {
    "bottom_nav": [
      { "id": "home", "label": "Home", "icon": "grid", "page": "mob-home" },
      { "id": "projects", "label": "Projects", "icon": "folder", "page": "mob-projects" },
      { "id": "capture", "label": "Capture", "icon": "camera", "page": "mob-capture", "fab": true },
      { "id": "account", "label": "Account", "icon": "user", "page": "mob-account" }
    ],
    "carousel": {
      "snap": true,
      "swipe_threshold_px": 50,
      "transition": "300ms cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "safe_area": {
      "top": "env(safe-area-inset-top, 0px)",
      "bottom": "env(safe-area-inset-bottom, 0px)"
    },
    "touch": {
      "min_target_size_px": 44,
      "min_gap_between_targets_px": 8,
      "tap_delay_fix": "touch-action: manipulation"
    }
  },

  "accessibility": {
    "color_contrast_ratio_min": 4.5,
    "focus_visible": true,
    "reduced_motion_respected": true,
    "aria_labels": true,
    "keyboard_navigation": true,
    "wcag_target": "AA"
  },

  "testing": {
    "target_browsers": [
      { "browser": "Safari", "platform": "iPhone", "versions": ["16", "17", "18"] },
      { "browser": "Chrome", "platform": "Android", "versions": ["120+"] },
      { "browser": "Safari", "platform": "iPad", "versions": ["16", "17"] },
      { "browser": "Chrome", "platform": "Desktop", "versions": ["120+"] },
      { "browser": "Firefox", "platform": "Desktop", "versions": ["120+"] }
    ],
    "breakpoints_to_test": ["375px", "390px", "768px", "1024px", "1440px"],
    "lighthouse_targets": {
      "performance": 90,
      "accessibility": 95,
      "best_practices": 90,
      "seo": 85
    }
  },

  "assets": {
    "logo_svg": "assets/autostudio-logo.svg",
    "favicon": "assets/favicon.ico",
    "og_image": "assets/og-image.jpg",
    "fonts": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap"
  },

  "meta": {
    "title": "AutoStudio — AI Automotive Photography",
    "description": "Transform your automotive photography with AI-powered studio processing. Background removal, color grading, and professional finishing in seconds.",
    "og_title": "AutoStudio — AI Automotive Photography",
    "og_description": "Transform your automotive photography with AI-powered studio processing.",
    "theme_color": "#CC2020",
    "apple_mobile_web_app": true,
    "apple_mobile_web_app_status_bar": "black-translucent"
  }
}
